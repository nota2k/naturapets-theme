  "title": "Bannière avec icones",
  "content": "<!-- wp:group {\"align\":\"full\",\"style\":{\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|small\",\"left\":\"var:preset|spacing|small\"},\"margin\":{\"top\":\"var:preset|spacing|large\",\"bottom\":\"var:preset|spacing|large\"}},\"dimensions\":{\"minHeight\":\"72vh\"}},\"backgroundColor\":\"neutral\",\"layout\":{\"type\":\"flex\",\"flexWrap\":\"nowrap\",\"justifyContent\":\"stretch\",\"orientation\":\"vertical\",\"verticalAlignment\":\"center\"}} -->\n<div class=\"wp-block-group alignfull has-neutral-background-color has-background\" style=\"min-height:72vh;margin-top:var(--wp--preset--spacing--large);margin-bottom:var(--wp--preset--spacing--large);padding-right:var(--wp--preset--spacing--small);padding-left:var(--wp--preset--spacing--small)\"><!-- wp:group {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:columns {\"verticalAlignment\":\"top\",\"style\":{\"spacing\":{\"blockGap\":{\"left\":\"var:preset|spacing|small\"},\"padding\":{\"top\":\"var:preset|spacing|x-large\",\"bottom\":\"var:preset|spacing|x-large\"}}}} -->\n<div class=\"wp-block-columns are-vertically-aligned-top\" style=\"padding-top:var(--wp--preset--spacing--x-large);padding-bottom:var(--wp--preset--spacing--x-large)\"><!-- wp:column {\"verticalAlignment\":\"top\",\"style\":{\"spacing\":{\"blockGap\":\"0px\"}}} -->\n<div class=\"wp-block-column is-vertically-aligned-top\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|x-small\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group\"><!-- wp:naturapets/icone {\"name\":\"naturapets/icone\",\"data\":{\"icone_image\":289,\"_icone_image\":\"field_icone_image\",\"icone_background\":\"#ffffff\",\"_icone_background\":\"field_icone_background\"},\"align\":\"center\",\"mode\":\"preview\"} /-->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"typography\":{\"lineHeight\":\"1.3\",\"fontStyle\":\"normal\",\"fontWeight\":\"700\"}}} -->\n<p class=\"has-text-align-center\" style=\"font-style:normal;font-weight:700;line-height:1.3\">Commandez votre médaillon</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"fontSize\":\"small\"} -->\n<p class=\"has-text-align-center has-small-font-size\">Choisissez le médaillon parfait pour votre compagnon parmi notre sélection</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"top\",\"style\":{\"spacing\":{\"blockGap\":\"9px\"}}} -->\n<div class=\"wp-block-column is-vertically-aligned-top\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|x-small\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group\"><!-- wp:naturapets/icone {\"name\":\"naturapets/icone\",\"data\":{\"icone_image\":287,\"_icone_image\":\"field_icone_image\",\"icone_background\":\"#ffffff\",\"_icone_background\":\"field_icone_background\"},\"align\":\"center\",\"mode\":\"preview\"} /-->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"typography\":{\"lineHeight\":\"1.3\",\"fontStyle\":\"normal\",\"fontWeight\":\"700\"}}} -->\n<p class=\"has-text-align-center\" style=\"font-style:normal;font-weight:700;line-height:1.3\">Créez le profil</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"fontSize\":\"small\"} -->\n<p class=\"has-text-align-center has-small-font-size\">Enregistrez les informations de votre animal et vos coordonnées en ligne</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"top\",\"style\":{\"spacing\":{\"blockGap\":\"9px\"}}} -->\n<div class=\"wp-block-column is-vertically-aligned-top\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|x-small\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group\"><!-- wp:naturapets/icone {\"name\":\"naturapets/icone\",\"data\":{\"icone_image\":286,\"_icone_image\":\"field_icone_image\",\"icone_background\":\"#ffffff\",\"_icone_background\":\"field_icone_background\"},\"align\":\"center\",\"mode\":\"preview\"} /-->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"typography\":{\"lineHeight\":\"1.3\",\"fontStyle\":\"normal\",\"fontWeight\":\"700\"}}} -->\n<p class=\"has-text-align-center\" style=\"font-style:normal;font-weight:700;line-height:1.3\">Attachez-le au collier</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"fontSize\":\"small\"} -->\n<p class=\"has-text-align-center has-small-font-size\">Fixez le médaillon au collier de votre animal, il est prêt à être protégé</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"top\",\"style\":{\"spacing\":{\"blockGap\":\"9px\"}}} -->\n<div class=\"wp-block-column is-vertically-aligned-top\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|x-small\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group\"><!-- wp:naturapets/icone {\"name\":\"naturapets/icone\",\"data\":{\"icone_image\":288,\"_icone_image\":\"field_icone_image\",\"icone_background\":\"#ffffff\",\"_icone_background\":\"field_icone_background\"},\"align\":\"center\",\"mode\":\"preview\"} /-->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"typography\":{\"lineHeight\":\"1.3\",\"fontStyle\":\"normal\",\"fontWeight\":\"700\"}}} -->\n<p class=\"has-text-align-center\" style=\"font-style:normal;font-weight:700;line-height:1.3\">Retrouvailles assurées</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"fontSize\":\"small\"} -->\n<p class=\"has-text-align-center has-small-font-size\">Si votre animal se perd, il suffit de scanner le QR code pour vous contacter</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->",
