xed\",\"flexSize\":\"80%\"}}} /--></div>\n<!-- /wp:group -->\n\n<!-- wp:columns {\"verticalAlignment\":\"center\",\"style\":{\"spacing\":{\"blockGap\":{\"top\":\"15px\",\"left\":\"var:preset|spacing|x-small\"}},\"layout\":{\"selfStretch\":\"fit\",\"flexSize\":null}}} -->\n<div class=\"wp-block-columns are-vertically-aligned-center\"><!-- wp:column {\"verticalAlignment\":\"center\",\"width\":\"58%\",\"style\":{\"spacing\":{\"blockGap\":\"0\",\"padding\":{\"right\":\"0\",\"left\":\"0\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-column is-vertically-aligned-center\" style=\"padding-right:0;padding-left:0;flex-basis:58%\"><!-- wp:woocommerce/product-price {\"isDescendentOfQueryLoop\":true,\"textColor\":\"secondary\",\"fontFamily\":\"fraunces\",\"fontSize\":\"large\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"600\"},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|secondary\"}}},\"spacing\":{\"margin\":{\"left\":\"0\",\"top\":\"0\",\"bottom\":\"0\",\"right\":\"0\"},\"padding\":{\"top\":\"0\",\"bottom\":\"0\",\"left\":\"0\",\"right\":\"0\"}},\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null}}} /--></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"center\",\"width\":\"47%\",\"style\":{\"spacing\":{\"padding\":{\"right\":\"0\",\"left\":\"0\",\"top\":\"0\",\"bottom\":\"0\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-column is-vertically-aligned-center\" style=\"padding-top:0;padding-right:0;padding-bottom:0;padding-left:0;flex-basis:47%\"><!-- wp:group {\"align\":\"full\",\"layout\":{\"type\":\"flex\",\"flexWrap\":\"nowrap\",\"justifyContent\":\"space-between\"}} -->\n<div class=\"wp-block-group alignfull\"><!-- wp:woocommerce/product-button {\"textAlign\":\"center\",\"width\":100,\"isDescendentOfQueryLoop\":true,\"align\":\"full\",\"backgroundColor\":\"secondary\",\"fontFamily\":\"inter\",\"style\":{\"border\":{\"radius\":{\"topLeft\":\"30px\",\"topRight\":\"30px\",\"bottomLeft\":\"30px\",\"bottomRight\":\"30px\"}},\"spacing\":{\"padding\":{\"top\":\"8px\",\"bottom\":\"8px\",\"left\":\"var:preset|spacing|x-small\",\"right\":\"var:preset|spacing|x-small\"},\"margin\":{\"right\":\"0\",\"left\":\"0\",\"top\":\"0\",\"bottom\":\"0\"}},\"color\":{\"text\":\"#ffffff\"},\"typography\":{\"fontWeight\":\"500\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#ffffff\"}}},\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null}}} /--></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->\n<!-- /wp:woocommerce/product-template -->\n\n<!-- wp:woocommerce/product-collection-no-results -->\n<!-- wp:group {\"fontSize\":\"small\",\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\",\"flexWrap\":\"wrap\"}} -->\n<div class=\"wp-block-group has-small-font-size\"><!-- wp:paragraph {\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\"><strong>Aucun résultat</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>Vous pouvez essayer <a class=\"wc-link-clear-any-filters\" href=\"#\">d’effacer les filtres</a> ou consulter <a class=\"wc-link-stores-home\" href=\"#\">l’accueil de notre boutique</a></p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n<!-- /wp:woocommerce/product-collection-no-results -->\n\n<!-- wp:query-pagination {\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n<!-- wp:query-pagination-previous /-->\n\n<!-- wp:query-pagination-numbers /-->\n\n<!-- wp:query-pagination-next /-->\n<!-- /wp:query-pagination --></div>\n<!-- /wp:woocommerce/product-collection --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->",
