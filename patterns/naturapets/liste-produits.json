  "title": "Liste produits",
  "content": "<!-- wp:group {\"metadata\":{\"name\":\"Liste produits\"},\"align\":\"full\",\"style\":{\"dimensions\":{\"minHeight\":\"\"},\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"}}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\",\"verticalAlignment\":\"center\"}} -->\n<div class=\"wp-block-group alignfull\" style=\"margin-top:0;margin-bottom:0\"><!-- wp:group {\"align\":\"wide\",\"style\":{\"layout\":{\"selfStretch\":\"fit\",\"flexSize\":null}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\",\"verticalAlignment\":\"center\"}} -->\n<div class=\"wp-block-group alignwide\"><!-- wp:woocommerce/product-collection {\"queryId\":14,\"query\":{\"woocommerceAttributes\":[],\"woocommerceStockStatus\":[\"instock\",\"outofstock\",\"onbackorder\"],\"taxQuery\":[],\"isProductCollectionBlock\":true,\"perPage\":5,\"pages\":0,\"offset\":0,\"postType\":\"product\",\"order\":\"asc\",\"orderBy\":\"title\",\"author\":\"\",\"search\":\"\",\"exclude\":[],\"sticky\":\"\",\"inherit\":false,\"featured\":false,\"woocommerceOnSale\":false,\"woocommerceHandPickedProducts\":[],\"filterable\":false,\"relatedBy\":{\"categories\":true,\"tags\":true}},\"tagName\":\"div\",\"displayLayout\":{\"type\":\"flex\",\"columns\":3,\"shrinkColumns\":true},\"dimensions\":{\"widthType\":\"fixed\",\"fixedWidth\":\"100%\"},\"queryContextIncludes\":[\"collection\"],\"__privatePreviewState\":{\"isPreview\":false,\"previewMessage\":\"Les produits dépendront de la page consultée.\"},\"align\":\"wide\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-woocommerce-product-collection alignwide\"><!-- wp:woocommerce/product-template {\"align\":\"full\",\"style\":{\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null}}} -->\n<!-- wp:group {\"metadata\":{\"name\":\"New Card Produit\",\"categories\":[\"naturapets-woocommerce\"],\"patternName\":\"naturapets/woocommerce-card-produit-html\"},\"className\":\"np-product-card\",\"style\":{\"dimensions\":{\"minHeight\":\"100%\"},\"spacing\":{\"blockGap\":\"0\",\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"0\",\"bottom\":\"0\",\"left\":\"0\",\"right\":\"0\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"450px\"}} -->\n<div class=\"wp-block-group np-product-card\" style=\"min-height:100%;margin-top:0;margin-bottom:0;padding-top:0;padding-right:0;padding-bottom:0;padding-left:0\"><!-- wp:group {\"metadata\":{\"name\":\"Card Produit-content\",\"categories\":[\"naturapets-woocommerce\"],\"patternName\":\"naturapets/woocommerce-card-produit-html\"},\"style\":{\"border\":{\"width\":\"0px\",\"style\":\"none\"},\"spacing\":{\"blockGap\":\"0\"},\"dimensions\":{\"minHeight\":\"100%\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\",\"verticalAlignment\":\"top\",\"flexWrap\":\"nowrap\"}} -->\n<div class=\"wp-block-group\" style=\"border-style:none;border-width:0px;min-height:100%\"><!-- wp:group {\"style\":{\"border\":{\"radius\":{\"topLeft\":\"20px\",\"topRight\":\"20px\"},\"top\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"right\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"bottom\":{\"width\":\"0px\",\"style\":\"none\",\"radius\":{\"topLeft\":\"20px\",\"topRight\":\"20px\"}},\"left\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"}},\"dimensions\":{\"minHeight\":\"100px\"},\"layout\":{\"selfStretch\":\"fit\",\"flexSize\":null},\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"0\",\"bottom\":\"0\",\"left\":\"0\",\"right\":\"0\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"100%\"}} -->\n<div class=\"wp-block-group\" style=\"border-top-left-radius:20px;border-top-right-radius:20px;border-top-color:var(--wp--preset--color--vert-eau);border-top-width:1px;border-right-color:var(--wp--preset--color--vert-eau);border-right-width:1px;border-bottom-style:none;border-bottom-width:0px;bo