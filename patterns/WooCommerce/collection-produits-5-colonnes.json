ht\":\"20px\",\"bottomLeft\":\"0px\",\"bottomRight\":\"0px\"},\"top\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"right\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"bottom\":{\"radius\":{\"topLeft\":\"20px\",\"topRight\":\"20px\",\"bottomLeft\":\"0px\",\"bottomRight\":\"0px\"},\"width\":\"0px\",\"style\":\"none\"},\"left\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"}},\"color\":{\"background\":\"#F0EDE8\"},\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null,\"columnSpan\":1,\"rowSpan\":1}}} /--></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"20px\",\"bottom\":\"20px\",\"left\":\"24px\",\"right\":\"24px\"},\"blockGap\":\"0px\"},\"dimensions\":{\"minHeight\":\"\"},\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null},\"border\":{\"right\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"bottom\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"left\":{\"color\":\"var:preset|color|vert-eau\",\"width\":\"1px\"},\"top\":[]}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"verticalAlignment\":\"space-between\",\"justifyContent\":\"stretch\",\"flexWrap\":\"wrap\"}} -->\n<div class=\"wp-block-group\" style=\"border-right-color:var(--wp--preset--color--vert-eau);border-right-width:1px;border-bottom-color:var(--wp--preset--color--vert-eau);border-bottom-width:1px;border-left-color:var(--wp--preset--color--vert-eau);border-left-width:1px;padding-top:20px;padding-right:24px;padding-bottom:20px;padding-left:24px\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"7px\"},\"layout\":{\"selfStretch\":\"fill\",\"flexSize\":null}},\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:post-title {\"isLink\":true,\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"500\",\"fontSize\":\"18px\",\"lineHeight\":\"1.5\",\"letterSpacing\":\"-0.44px\"},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|secondary\"}}}},\"textColor\":\"secondary\",\"fontFamily\":\"nunito-sans\"} /-->\n\n<!-- wp:woocommerce/product-summary {\"isDescendentOfQueryLoop\":true,\"summaryLength\":20,\"fontFamily\":\"inter\",\"style\":{\"typography\":{\"fontSize\":\"14px\",\"lineHeight\":\"1.43\",\"letterSpacing\":\"-0.15px\"},\"color\":{\"text\":\"#8A8A8A\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8A8A8A\"}}}}} /--></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|x-small\",\"margin\":{\"top\":\"10px\"}},\"layout\":{\"selfStretch\":\"fill\"}},\"layout\":{\"type\":\"flex\",\"flexWrap\":\"wrap\",\"verticalAlignment\":\"bottom\",\"justifyContent\":\"space-between\"}} -->\n<div class=\"wp-block-group\" style=\"margin-top:10px\"><!-- wp:woocommerce/product-price {\"isDescendentOfQueryLoop\":true,\"textColor\":\"secondary\",\"fontFamily\":\"fraunces\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"500\",\"fontSize\":\"24px\",\"lineHeight\":\"1.33\",\"letterSpacing\":\"0.07px\"},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|secondary\"}}}}} /-->\n\n<!-- wp:woocommerce/product-button {\"isDescendentOfQueryLoop\":true,\"backgroundColor\":\"secondary\",\"fontFamily\":\"inter\",\"style\":{\"border\":{\"radius\":\"24px\"},\"spacing\":{\"padding\":{\"top\":\"7px\",\"bottom\":\"7px\",\"left\":\"16px\",\"right\":\"16px\"}},\"color\":{\"text\":\"#ffffff\"},\"typography\":{\"fontSize\":\"14px\",\"fontWeight\":\"500\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#ffffff\"}}}}} /--></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->\n<!-- /wp:woocommerce/product-template --></div>\n<!-- /wp:woocommerce/product-collection -->\n\n<!-- wp:spacer {\"height\":\"calc( 0.25 * var(\\u002d\\u002dwp\\u002d\\u002dstyle\\u002d\\u002droot\\u002d\\u002dpadding-right, var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dgap\\u002d\\u002dhorizontal)))\"} -->\n<div style=\"height:calc( 0.25 * var(--wp--style--root--padding-right, var(--wp--custom--gap--horizontal)))\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n<!-- /wp:spacer --></div>\n<!-- /wp:group -->",
